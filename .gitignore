/bin/
/dist/
*.out
!testdata/fixtures/*.out
.DS_Store

# Scratch build dirs the pipeline tests create under the module tree so the
# generated programs link the runtime offline. Removed on success, ignored so
# an interrupted run never leaves a tracked file behind.
/genrun-*/

# compiled go test binaries
*.test

# Python bytecode caches. A fixture with sibling modules under files/ leaves a
# __pycache__ behind when the oracle runs; the .py sources are the truth, so
# keep the caches out of the tree.
__pycache__/
*.pyc
